@article{righelli2022,
    author = {Righelli, Dario and Weber, Lukas M and Crowell, Helena L and Pardo, Brenda and Collado-Torres, Leonardo and Ghazanfar, Shila and Lun, Aaron T L and Hicks, Stephanie C and Risso, Davide},
