@article{gupta2019,
author={Gupta, Shashank
and Mortensen, Martin S.
and Schj{\o}rring, Susanne
and Trivedi, Urvish
and Vestergaard, Gisle
and Stokholm, Jakob
and Bisgaard, Hans
and Krogfelt, Karen A.
and S{\o}rensen, S{\o}ren J.},
title={Amplicon sequencing provides more accurate microbiome information in healthy children compared to culturing},
journal={Communications Biology},
year={2019},
month={Aug},
day={05},
volume={2},
number={1},
pages={291},
abstract={Next-Generation Sequencing (NGS) of 16S rRNA gene is now one of the most widely used application to investigate the microbiota at any given body site in research. Since NGS is more sensitive than traditional culture methods (TCMs), many studies have argued for them to replace TCMs. However, are we really ready for this transition? Here we compare the diagnostic efficiency of the two methods using a large number of samples (n{\thinspace}={\thinspace}1,748 fecal and n{\thinspace}={\thinspace}1,790 hypopharyngeal), among healthy children at different time points. Here we show that bacteria identified by NGS represented 75.70{\%} of the unique bacterial species cultured in each sample, while TCM only identified 23.86{\%} of the bacterial species found by amplicon sequencing. We discuss the pros and cons of both methods and provide perspective on how NGS can be implemented effectively in clinical settings.},
issn={2399-3642},
doi={10.1038/s42003-019-0540-1}
}

